{
  "name": "@solana-zk-kyc/sdk",
  "version": "1.0.0",
  "description": "Privacy-preserving KYC/AML compliance SDK for Solana blockchain using Zero-Knowledge Proofs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -m esnext --outDir dist --module esnext",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "kyc",
    "compliance",
    "zk-proof",
    "zero-knowledge",
    "defi",
    "nft",
    "identity",
    "did",
    "verifiable-credentials"
  ],
  "author": "Solana ZK-KYC Team",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@solana/web3.js": "^1.90.0",
    "axios": "^1.6.7",
    "did-resolver": "^4.1.0",
    "ethers": "^6.11.1",
    "snarkjs": "^0.7.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.8",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
